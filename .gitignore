# =====================================================================
# Dependencies
# =====================================================================
node_modules/
.pnp
.pnp.js

# Workspace-lokale Lock-Files — wir nutzen ausschließlich den Root-Lockfile
backend/package-lock.json
frontend/package-lock.json

# =====================================================================
# Build-Output
# =====================================================================
dist/
build/
out/
.cache/

# =====================================================================
# Environment-Dateien
# Tracked bleiben: .env.example, .env.development, .env.production, .env.test
# Ignoriert werden Dateien mit echten Secrets
# =====================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# =====================================================================
# Tests / CI-Artefakte
# =====================================================================
coverage/
.nyc_output/

# Playwright (alle Varianten)
playwright-report/
playwright-report-smoke/
frontend/playwright-report/
frontend/playwright-report-smoke/
frontend/e2e/test-results/
frontend/e2e/test-results-smoke/
frontend/blob-report/
frontend/playwright/.cache/

# Visual-Audit Screenshots (werden bei Bedarf regeneriert)
frontend/e2e/screenshots/

# =====================================================================
# Logs & Runtime
# =====================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

pids/
*.pid
*.seed
*.pid.lock

