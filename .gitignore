.npm
.eslintcache
.stylelintcache
.vite/
.rpt2_cache/
.rts2_cache_*/

# =====================================================================
# AI-Tools & Claude Code
# settings.json + skills/ sind geteiltes Team-Wissen und bleiben tracked.
