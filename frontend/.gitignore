# =====================================================================
# Frontend-spezifische Ergänzungen (Root .gitignore deckt das meiste ab)
# =====================================================================

# Dependencies (Sicherheitsnetz falls direkt in frontend/ gearbeitet wird)
node_modules/
.pnp
.pnp.js

# Build-Output
dist/
dist-ssr/
*.local

# Environment-Dateien mit Secrets
.env
.env.local
.env.*.local

# Logs
*.log

# Testing
coverage/
.nyc_output

# Playwright
/e2e/test-results/
/e2e/test-results-smoke/
/e2e/screenshots/
/playwright-report/
/playwright-report-smoke/
/blob-report/
/playwright/.cache/

# Vite-Cache
.vite/

# IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
._*
Thumbs.db

# Temporär
*.tmp
*.temp
.cache/

# Optional
.npm
.eslintcache
.stylelintcache

# .htaccess bleibt tracked falls vorhanden
!.htaccess
