{
  "name": "urban-golf-frontend",
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "build:test": "vite build --mode test",
    "preview": "vite preview",
    "preview:prod": "vite preview --mode production",
    "preview:test": "vite preview --mode test",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "vue-tsc --noEmit",
    "test:e2e:smoke": "playwright test --config=playwright.smoke.config.ts",
    "test:e2e:smoke:headed": "playwright test --config=playwright.smoke.config.ts --headed",
    "test:visual": "node e2e/visual-audit.mjs",
    "test:all": "npm run lint && npm run type-check && npm run test && npm run test:e2e:smoke"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "@vueuse/core": "^14.0.0",
    "axios": "^1.12.0",
    "marked": "^18.0.0",
    "nanoid": "^5.1.6",
    "pinia": "^3.0.4",
    "vue": "^3.4.15",
    "vue-i18n": "^11.1.6",
    "vue-router": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^17.0.0",
    "happy-dom": "^20.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.56.0",
    "vite": "^8.0.3",
    "vite-plugin-compression2": "^2.4.0",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^4.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.4"
  }
}
